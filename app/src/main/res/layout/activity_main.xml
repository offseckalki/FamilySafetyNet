<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/locationStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Location will appear here"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="#f0f0f0"
        android:layout_alignParentTop="true"/>

    <Button
        android:id="@+id/startTrackingBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Tracking"
        android:layout_below="@id/locationStatusText"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/stopTrackingBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stop Tracking"
        android:layout_below="@id/startTrackingBtn"
        android:layout_marginTop="8dp"/>

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/stopTrackingBtn"/>
</RelativeLayout>
